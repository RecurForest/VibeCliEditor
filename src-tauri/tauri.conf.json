{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeCliEditor",
  "version": "1.0.2",
  "identifier": "com.jipei.vibeclieditor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeCliEditor",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 680,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
